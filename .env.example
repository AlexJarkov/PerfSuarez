# Copia este archivo a .env y ajusta los valores.
# BASE_URL del ERP que provee el JSON del catálogo (sin slash final).
# Vacío = usar perfumes.json estático (fallback).
BASE_URL=
# Interruptor de la funcionalidad API: false = ignora BASE_URL y usa siempre
# el JSON estático (js/data/perfumes.json), sin llamar al ERP.
CATALOG_API_ENABLED=true
DISABLE_SHELL_REDIRECT=false
